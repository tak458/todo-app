{
  "name": "todo-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "type-check": "turbo type-check",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "generate": "turbo generate",
    "test:ci": "turbo test:ci"
  },
  "devDependencies": {
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "tsx": "4.23.1",
    "turbo": "2.10.5"
  },
  "packageManager": "npm@12.0.1"
}
