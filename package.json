{
  "name": "todo-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "type-check": "turbo type-check",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "generate": "turbo generate",
    "test:ci": "turbo test:ci"
  },
  "devDependencies": {
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "tsx": "4.22.4",
    "turbo": "2.9.16"
  },
  "packageManager": "npm@11.16.0"
}
